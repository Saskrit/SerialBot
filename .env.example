# Local development only — on Railway, set these in Service → Variables
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789
ADMIN_SECRET=choose-a-strong-password-here

# MongoDB Atlas — allow 0.0.0.0/0 in Network Access for Railway deploys
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?appName=SerialHub
MONGODB_DB=serialhub

# Private storage channel IDs (comma-separated). Bot must be admin in each.
# STORAGE_CHANNEL_ID still works for a single channel.
STORAGE_CHANNEL_IDS=-1001234567890,-1009876543210
# STORAGE_CHANNEL_ID=-1001234567890

# Payments — contact on Telegram for VIP / unlocks
PAYMENT_CONTACT_USERNAME=godthough

# Optional
NOTIFY_ON_NEW_EPISODE=true
# Auto promo for Episode Alert membership (hours between reminders to non-subscribers)
NOTIFY_PROMO_INTERVAL_HOURS=3
# Trial timer for free users: off, 10s, 1min, 1hr, etc. (set via /admin → Trial Episode Timer)
TELEGRAM_PROXY=
PORT=10000
RESTART_ON_CRASH=true
